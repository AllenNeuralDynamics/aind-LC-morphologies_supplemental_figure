{
	"version": 1,
	"base_image": "codeocean/mambaforge3:23.1.0-4-python3.10.12-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"conda": {
			"packages": [
				{
					"name": "hdbscan",
					"version": "0.8.33"
				},
				{
					"name": "jupyterlab",
					"version": "4.0.9"
				},
				{
					"name": "k3d",
					"version": "2.16.0"
				}
			]
		},
		"pip3": {
			"packages": [
				{
					"name": "lc-reconstruction-analysis",
					"version": "0.0.27"
				},
				{
					"name": "matplotlib",
					"version": "3.8.2"
				},
				{
					"name": "networkx",
					"version": "3.2.1"
				},
				{
