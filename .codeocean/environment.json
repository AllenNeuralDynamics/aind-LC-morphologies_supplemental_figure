					"version": "1.11.4"
				},
				{
					"name": "seaborn",
					"version": "0.13.0"
				},
				{
					"name": "tqdm",
					"version": "4.66.1"
				},
				{
					"name": "umap-learn",
					"version": "0.5.5"
				}
			],
			"options": {},
			"pre_install_options": {}
		}
	}
}